            "index": 0
          }
        ]
      ]
    },
    "Invite User via Auth": {
      "main": [
        [
          {
            "node": "Create Client Profile",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create Client Profile": {
      "main": [
        [
          {
            "node": "Create Welcome Notification",
            "type": "main",
            "index": 0
          },
          {
            "node": "Log Cyrus Onboarding",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Cyrus Onboarding": {
      "main": [
        [
          {
            "node": "Respond OK",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
