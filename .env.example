# AuraFlow Client App — Environment Variables
# Copy this to .env.local and fill in the values

# Supabase (get from: supabase.com/dashboard/project/bfzdcyuyilesubtgbhdc/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://bfzdcyuyilesubtgbhdc.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API (get from: console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# n8n Webhooks
N8N_WEBHOOK_BASE=https://aurabazaar.app.n8n.cloud/webhook

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Change to https://app.auraflowusa.com for production
